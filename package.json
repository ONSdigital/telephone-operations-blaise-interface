{
  "name": "express-react",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "build": "yarn build:client && yarn build:server",
    "build:client": "yarn vite build",
    "build:server": "yarn tsc --project tsconfig.server.build.json",
    "dev": "yarn concurrently --kill-others-on-fail --names \"server,web\" \"yarn dev:server\" \"yarn dev:client\"",
    "dev:client": "yarn vite",
    "dev:server": "tsx watch src/server/index.ts | yarn pino-pretty -c -t",
    "gcp-build": "yarn build",
    "lint": "yarn typecheck && yarn eslint . --max-warnings 0 && yarn prettier --check . && yarn knip",
    "lint-fix": "yarn eslint . --fix && yarn prettier --write . && yarn knip --fix",
    "spellcheck": "yarn cspell \"**/*.{ts,tsx,json,jsonc,yml,yaml,md}\" --no-progress --no-summary",
    "start": "node ./build/server/index.js",
    "test": "yarn vitest run --coverage",
    "test-watch": "yarn vitest",
    "typecheck": "yarn tsc --noEmit -p tsconfig.client.json && yarn tsc --noEmit -p tsconfig.server.json && yarn tsc --noEmit -p tsconfig.tooling.json",
    "start-server": "tsc --project tsconfig.server.json && node ./dist/index.js",
    "start-react": "react-scripts start",
    "build-react": "react-scripts build"
  },
  "proxy": "http://localhost:5000",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pre-commit": [
    "lint-fix"
  ],
  "dependencies": {
    "@google-cloud/logging": "^11.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pino": "^7.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.18.1",
    "blaise-api-node-client": "git+https://github.com/ONSdigital/blaise-api-node-client#v3.0.0",
    "blaise-design-system-react-components": "git+https://github.com/ONSdigital/blaise-design-system-react-components#v2.0.0",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "formik": "^2.4.9",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "history": "^5.3.0",
    "jest-cucumber": "^4.5.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tsx": "^4.23.0",
    "typescript": "~7.0.2"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/plugin-transform-react-jsx": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@eslint-react/eslint-plugin": "^5.13.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/ejs": "^3.1.5",
    "@types/lodash": "^4.17.24",
    "@types/react-router-dom": "^5.3.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "axios-mock-adapter": "^2.1.0",
    "cspell": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsonc": "^3.3.0",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "jest-environment-jsdom": "^30.4.1",
    "jest-environment-node": "^30.4.1",
    "jest-extended": "^7.0.0",
    "jsonc-eslint-parser": "^3.1.0",
    "knip": "^6.25.0",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "typemoq": "^2.1.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "yarn@4.17.1"
}
